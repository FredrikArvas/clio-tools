# clio-agent-obit — .env.example
# Kopiera till .env och fyll i lösenordet. Lägg aldrig .env i Git.
# Icke-hemlig konfiguration (host, port, user) ligger i config.yaml.

# SMTP-lösenord — nyckelnamnet matchas mot config.yaml smtp.password_env
SMTP_PASSWORD=

# DEPRECATED i 0.2.0: RSS_URLS användes av den gamla familjesidan-RSS-adaptern.
# Familjesidan exponerar inte längre publik RSS — källor läggs nu till via
# sources.yaml. Variabeln läses fortfarande av source_familjesidan_rss.py
# om du återaktiverar den manuellt.
# RSS_URLS=

# Valfri: HTTP User-Agent för discover.py och HTML-adaptrar
# DISCOVER_USER_AGENT=clio-agent-obit/0.2 (+https://arvas.se)

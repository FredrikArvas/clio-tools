<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Listvy -->
  <record id="view_uap_source_tree" model="ir.ui.view">
    <field name="name">uap.source.list</field>
    <field name="model">uap.source</field>
    <field name="arch" type="xml">
      <list>
        <field name="source_id"/>
        <field name="name"/>
        <field name="source_type"/>
        <field name="tier"/>
        <field name="language"/>
        <field name="published_date"/>
        <field name="encounter_count" string="Encounters"/>
      </list>
    </field>
  </record>

  <!-- Formvy -->
  <record id="view_uap_source_form" model="ir.ui.view">
    <field name="name">uap.source.form</field>
    <field name="model">uap.source</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group string="Identification">
            <field name="source_id" placeholder="ufo-se_1974_vallentuna"/>
            <field name="name"/>
            <field name="source_type"/>
            <field name="tier"/>
          </group>
          <group string="Details">
            <field name="url" widget="url" placeholder="https://"/>
            <field name="published_date"/>
            <field name="language"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Kanbanvy -->
  <record id="view_uap_source_kanban" model="ir.ui.view">
    <field name="name">uap.source.kanban</field>
    <field name="model">uap.source</field>
    <field name="arch" type="xml">
      <kanban default_group_by="source_type">
        <field name="source_id"/>
        <field name="name"/>
        <field name="tier"/>
        <field name="url"/>
        <field name="encounter_count"/>
        <templates>
          <t t-name="card">
            <div class="fw-bold">
              <field name="name"/>
            </div>
            <div class="text-muted small">
              <field name="source_id"/>
            </div>
            <div class="mt-1">
              <span class="badge rounded-pill text-bg-primary me-1">
                <field name="tier"/>
              </span>
              <span class="badge rounded-pill text-bg-secondary">
                <field name="encounter_count"/> enc.
              </span>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- Grafvy -->
  <record id="view_uap_source_graph" model="ir.ui.view">
    <field name="name">uap.source.graph</field>
    <field name="model">uap.source</field>
    <field name="arch" type="xml">
      <graph string="Sources" type="bar">
        <field name="source_type" type="row"/>
        <field name="tier" type="col"/>
      </graph>
    </field>
  </record>

  <!-- Pivotvy -->
  <record id="view_uap_source_pivot" model="ir.ui.view">
    <field name="name">uap.source.pivot</field>
    <field name="model">uap.source</field>
    <field name="arch" type="xml">
      <pivot string="Sources">
        <field name="source_type" type="row"/>
        <field name="tier" type="col"/>
      </pivot>
    </field>
  </record>

  <!-- Sökvy -->
  <record id="view_uap_source_search" model="ir.ui.view">
    <field name="name">uap.source.search</field>
    <field name="model">uap.source</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="source_id"/>
        <filter string="Tier 1" name="tier1" domain="[('tier','=','tier_1')]"/>
        <filter string="Tier 2" name="tier2" domain="[('tier','=','tier_2')]"/>
        <group expand="0" string="Group By">
          <filter string="Type" name="by_type" context="{'group_by': 'source_type'}"/>
          <filter string="Tier" name="by_tier" context="{'group_by': 'tier'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Action -->
  <record id="action_uap_source" model="ir.actions.act_window">
    <field name="name">Sources</field>
    <field name="res_model">uap.source</field>
    <field name="view_mode">list,kanban,graph,pivot,form</field>
    <field name="search_view_id" ref="view_uap_source_search"/>
  </record>

</odoo>

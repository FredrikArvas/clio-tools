<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Kategorin döljs från Inställningar → Användare (intern cockpit-behörighet) -->
  <record id="module_category_clio" model="ir.module.category">
    <field name="name">Clio</field>
    <field name="description">Behörigheter för Clio Cockpit och agenter</field>
    <field name="sequence">100</field>
    <field name="visible" eval="False"/>
  </record>

  <!-- Bas-grupp: kan se agenter, RAG och bibliotek -->
  <record id="group_clio_user" model="res.groups">
    <field name="name">Clio User</field>
    <field name="category_id" ref="module_category_clio"/>
  </record>

  <!-- Admin-grupp: ärver User + ser Server och Mail Admin -->
  <record id="group_clio_admin" model="res.groups">
    <field name="name">Clio Admin</field>
    <field name="category_id" ref="module_category_clio"/>
    <field name="implied_ids" eval="[(4, ref('group_clio_user'))]"/>
    <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
  </record>

</odoo>

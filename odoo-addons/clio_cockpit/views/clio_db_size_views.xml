<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_clio_db_size_list" model="ir.ui.view">
    <field name="name">clio.db.size.list</field>
    <field name="model">clio.db.size</field>
    <field name="arch" type="xml">
      <list string="Databasstorlekar" create="false" edit="false" delete="false"
            decoration-warning="total_size_bytes &gt; 524288000">
        <field name="db_name"               string="Databas"/>
        <field name="pg_size_pretty"        string="PostgreSQL"/>
        <field name="filestore_size_pretty" string="Filestore"/>
        <field name="total_size_pretty"     string="Totalt"/>
        <field name="last_synced"           string="Senast synkad"/>
        <field name="total_size_bytes"      column_invisible="True"/>
      </list>
    </field>
  </record>

  <!-- Server-action: synkar automatiskt och öppnar sedan listan -->
  <record id="action_open_db_sizes" model="ir.actions.server">
    <field name="name">Databasstorlekar</field>
    <field name="model_id" ref="model_clio_db_size"/>
    <field name="state">code</field>
    <field name="code">action = model.action_sync_and_open()</field>
  </record>

</odoo>

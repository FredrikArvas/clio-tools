<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ══════════════════════════════════════════════════════════════════════
       VY: Heartbeat — lista
  ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_clio_tool_heartbeat_list" model="ir.ui.view">
    <field name="name">clio.tool.heartbeat.list</field>
    <field name="model">clio.tool.heartbeat</field>
    <field name="arch" type="xml">
      <list string="Agenthälsa" decoration-success="status == 'ok'"
                                decoration-warning="status == 'warning'"
                                decoration-danger="status == 'error'">
        <header>
          <button name="action_sync_heartbeat" type="object"
                  string="Synka systemstatus" class="btn-primary"/>
        </header>
        <field name="status_icon" string=" " width="30px"/>
        <field name="tool_name"        string="Verktyg"/>
        <field name="last_run"         string="Senaste körning"/>
        <field name="status"           string="Status" column_invisible="1"/>
        <field name="items_processed"  string="Objekt"/>
        <field name="message"          string="Meddelande"/>
      </list>
    </field>
  </record>

  <!-- ══════════════════════════════════════════════════════════════════════
       VY: Heartbeat — formulär
  ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_clio_tool_heartbeat_form" model="ir.ui.view">
    <field name="name">clio.tool.heartbeat.form</field>
    <field name="model">clio.tool.heartbeat</field>
    <field name="arch" type="xml">
      <form string="Agenthälsa">
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="status_icon" readonly="1"/> <field name="tool_name" readonly="1"/>
            </h1>
          </div>
          <group>
            <group string="Körning">
              <field name="last_run"        string="Senaste körning"/>
              <field name="status"          string="Status"/>
              <field name="items_processed" string="Bearbetade objekt"/>
            </group>
            <group string="Detaljer">
              <field name="message" string="Meddelande"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ══════════════════════════════════════════════════════════════════════
       ACTION
  ══════════════════════════════════════════════════════════════════════ -->
  <record id="action_clio_tool_heartbeat" model="ir.actions.act_window">
    <field name="name">Agenthälsa</field>
    <field name="res_model">clio.tool.heartbeat</field>
    <field name="view_mode">list,form</field>
    <field name="context">{}</field>
  </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Listvy for clio.partner.link -->
  <record id="view_clio_partner_link_list" model="ir.ui.view">
    <field name="name">clio.partner.link.list</field>
    <field name="model">clio.partner.link</field>
    <field name="arch" type="xml">
      <list create="true" delete="true">
        <field name="relation_label" string="Relation"/>
        <field name="to_partner_id" string="Person"/>
      </list>
    </field>
  </record>

  <!-- Lagg till Clio-flik pa res.partner-formularet -->
  <record id="view_partner_form_clio_obit" model="ir.ui.view">
    <field name="name">res.partner.form.clio_obit</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">

      <notebook position="inside">
        <page string="Clio Obit" name="clio_obit">

          <group string="Identitet">
            <field name="clio_obit_birth_name" placeholder="T.ex. Ulrika Johnsson"/>
            <field name="clio_obit_birth_approx" placeholder="T.ex. 1952, ca 1952, mars 1952, 1952-03-15"/>
            <field name="clio_obit_birth_year" readonly="1"
                   invisible="clio_obit_birth_year == 0"/>
            <field name="clio_family_role" placeholder="T.ex. farfar, faster, granne"/>
          </group>

          <group string="Bevakningar">
            <field name="clio_obit_watch" readonly="1" string="Bevakad"/>
            <field name="watch_ids" nolabel="1" string="Bevakningsrelationer">
              <list editable="bottom">
                <field name="user_id" string="Bevakande användare"
                       options="{'no_create': True, 'no_open': False}"/>
                <field name="priority" widget="badge"
                       decoration-danger="priority == 'viktig'"
                       decoration-warning="priority == 'normal'"
                       decoration-muted="priority == 'bra_att_veta'"/>
              </list>
            </field>
          </group>

          <field name="clio_link_ids" string="Familjerelationer" nolabel="1"/>

        </page>
      </notebook>

    </field>
  </record>

</odoo>

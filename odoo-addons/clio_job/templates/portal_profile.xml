<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Profil — läsläge -->
  <template id="portal_profile" name="Clio Job — Min profil">
    <t t-call="portal.portal_layout">
      <t t-set="breadcrumbs_searchbar" t-value="False"/>

      <t t-call="portal.portal_record_layout">
        <t t-set="card_header">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Min Clio Job-profil</h5>
            <a href="/my/clio-job/edit" class="btn btn-sm btn-primary">
              Redigera
            </a>
          </div>
        </t>
        <t t-set="card_body">
          <t t-if="not profile">
            <div class="alert alert-info">
              Du har ingen aktiv jobbsignalprofil ännu.
              Kontakta <a href="mailto:fredrik@arvas.se">fredrik@arvas.se</a> för att komma igång.
            </div>
          </t>
          <t t-if="profile">
            <div t-if="request.params.get('success')" class="alert alert-success">
              Profilen sparades.
            </div>

            <dl class="row">
              <dt class="col-sm-3">Roll</dt>
              <dd class="col-sm-9"><t t-esc="profile.role or '—'"/></dd>

              <dt class="col-sm-3">Senioritet</dt>
              <dd class="col-sm-9"><t t-esc="profile.seniority or '—'"/></dd>

              <dt class="col-sm-3">Geografi</dt>
              <dd class="col-sm-9"><t t-esc="profile.geography or '—'"/></dd>

              <dt class="col-sm-3">Hybrid OK</dt>
              <dd class="col-sm-9"><t t-esc="'Ja' if profile.hybrid_ok else 'Nej'"/></dd>

              <dt class="col-sm-3">Rapport-e-post</dt>
              <dd class="col-sm-9"><t t-esc="profile.report_email or '(använder kontaktens e-post)'"/></dd>
            </dl>

            <h6 class="mt-3">Bakgrund</h6>
            <pre class="bg-light p-2 rounded" style="white-space:pre-wrap;"><t t-esc="profile.background or '—'"/></pre>

            <h6 class="mt-3">Utbildning</h6>
            <pre class="bg-light p-2 rounded" style="white-space:pre-wrap;"><t t-esc="profile.education or '—'"/></pre>

            <h6 class="mt-3">Målroller</h6>
            <pre class="bg-light p-2 rounded" style="white-space:pre-wrap;"><t t-esc="profile.target_roles or '—'"/></pre>

            <h6 class="mt-3">Signalnyckelord</h6>
            <pre class="bg-light p-2 rounded" style="white-space:pre-wrap;"><t t-esc="profile.signal_keywords or '—'"/></pre>

            <div class="mt-3">
              <a href="/my/clio-job/matches" class="btn btn-outline-secondary btn-sm">
                Visa matchningshistorik
                <t t-if="clio_job_match_count">
                  (<t t-esc="clio_job_match_count"/>)
                </t>
              </a>
            </div>
          </t>
        </t>
      </t>
    </t>
  </template>

  <!-- Profil — redigeringsläge -->
  <template id="portal_profile_edit" name="Clio Job — Redigera profil">
    <t t-call="portal.portal_layout">
      <t t-call="portal.portal_record_layout">
        <t t-set="card_header">
          <h5 class="mb-0">Redigera min Clio Job-profil</h5>
        </t>
        <t t-set="card_body">
          <t t-if="not profile">
            <div class="alert alert-warning">Ingen profil hittades.</div>
          </t>
          <t t-if="profile">
            <form action="/my/clio-job/edit" method="post">
              <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Roll</label>
                <div class="col-sm-9">
                  <input type="text" name="role" class="form-control"
                         t-att-value="profile.role or ''"/>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Senioritet</label>
                <div class="col-sm-9">
                  <input type="text" name="seniority" class="form-control"
                         t-att-value="profile.seniority or ''"/>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Geografi</label>
                <div class="col-sm-9">
                  <input type="text" name="geography" class="form-control"
                         t-att-value="profile.geography or ''"/>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Hybrid OK</label>
                <div class="col-sm-9 pt-2">
                  <input type="checkbox" name="hybrid_ok"
                         t-att-checked="'checked' if profile.hybrid_ok else None"/>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Rapport-e-post</label>
                <div class="col-sm-9">
                  <input type="email" name="report_email" class="form-control"
                         t-att-value="profile.report_email or ''"
                         placeholder="Lämna tomt för att använda kontaktens e-post"/>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Bakgrund</label>
                <div class="col-sm-9">
                  <textarea name="background" class="form-control" rows="4"><t t-esc="profile.background or ''"/></textarea>
                  <small class="text-muted">En post per rad.</small>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Utbildning</label>
                <div class="col-sm-9">
                  <textarea name="education" class="form-control" rows="3"><t t-esc="profile.education or ''"/></textarea>
                  <small class="text-muted">En post per rad.</small>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Målroller</label>
                <div class="col-sm-9">
                  <textarea name="target_roles" class="form-control" rows="4"><t t-esc="profile.target_roles or ''"/></textarea>
                  <small class="text-muted">En roll per rad.</small>
                </div>
              </div>
              <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Signalnyckelord</label>
                <div class="col-sm-9">
                  <textarea name="signal_keywords" class="form-control" rows="5"><t t-esc="profile.signal_keywords or ''"/></textarea>
                  <small class="text-muted">Ett nyckelord per rad (t.ex. ny GD, förvärv, digitaliseringsprogram).</small>
                </div>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Spara</button>
                <a href="/my/clio-job" class="btn btn-outline-secondary">Avbryt</a>
              </div>
            </form>
          </t>
        </t>
      </t>
    </t>
  </template>

</odoo>

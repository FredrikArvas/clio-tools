<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Lagg till Clio Job-flik pa res.partner-formularet -->
  <record id="view_partner_form_clio_job" model="ir.ui.view">
    <field name="name">res.partner.form.clio_job</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">

      <notebook position="inside">
        <page string="Clio Job" name="clio_job">

          <group string="Job Signal Monitoring">
            <field name="clio_job_watch"/>
          </group>

          <field name="clio_job_profile_ids"
                 string="Candidate Profile"
                 nolabel="1"
                 invisible="not clio_job_watch">
            <list>
              <field name="role" string="Role"/>
              <field name="seniority" string="Seniority"/>
              <field name="geography" string="Geography"/>
              <field name="match_count" string="Matches"/>
              <field name="active" optional="hide"/>
            </list>
          </field>

        </page>
      </notebook>

    </field>
  </record>

</odoo>

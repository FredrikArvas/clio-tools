<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Listvy -->
  <record id="view_clio_job_profile_tree" model="ir.ui.view">
    <field name="name">clio.job.profile.list</field>
    <field name="model">clio.job.profile</field>
    <field name="arch" type="xml">
      <list>
        <field name="partner_id"/>
        <field name="role"/>
        <field name="seniority"/>
        <field name="geography"/>
        <field name="match_count" string="Matches"/>
        <field name="active" optional="hide"/>
      </list>
    </field>
  </record>

  <!-- Formvy -->
  <record id="view_clio_job_profile_form" model="ir.ui.view">
    <field name="name">clio.job.profile.form</field>
    <field name="model">clio.job.profile</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group string="Contact">
            <field name="partner_id"/>
            <field name="report_email" placeholder="Leave empty → partner email is used"/>
            <field name="active"/>
          </group>

          <group string="Profile">
            <field name="role" placeholder="Current job title or role"/>
            <field name="seniority" placeholder='E.g. "Senior / Executive"'/>
            <field name="geography" placeholder='E.g. "Stockholm"'/>
            <field name="hybrid_ok"/>
          </group>

          <notebook>
            <page string="Background &amp; Education">
              <group string="Career History" col="1">
                <field name="background"
                       placeholder="One entry per line"
                       nolabel="1"/>
              </group>
              <group string="Education" col="1">
                <field name="education"
                       placeholder="One entry per line"
                       nolabel="1"/>
              </group>
            </page>

            <page string="Monitoring Settings">
              <group string="Target Roles" col="1">
                <field name="target_roles"
                       placeholder="One role per line"
                       nolabel="1"/>
              </group>
              <group string="Signal Keywords" col="1">
                <field name="signal_keywords"
                       placeholder="One keyword per line (e.g. new CEO, acquisition)"
                       nolabel="1"/>
              </group>
            </page>

            <page string="Match History">
              <field name="match_ids" nolabel="1">
                <list create="false" delete="false">
                  <field name="sent_at" string="Sent"/>
                  <field name="article_title" string="Title"/>
                  <field name="signal_type" string="Signal Type"/>
                  <field name="match_score" string="Score"/>
                  <field name="recommended_action" string="Action"/>
                  <field name="article_url" string="URL"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Menypost -->
  <record id="action_clio_job_profile" model="ir.actions.act_window">
    <field name="name">Clio Job — Profiles</field>
    <field name="res_model">clio.job.profile</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Listvy -->
  <record id="view_clio_job_profile_tree" model="ir.ui.view">
    <field name="name">clio.job.profile.list</field>
    <field name="model">clio.job.profile</field>
    <field name="arch" type="xml">
      <list>
        <field name="partner_id"/>
        <field name="role"/>
        <field name="seniority"/>
        <field name="geography"/>
        <field name="match_count" string="Matchningar"/>
        <field name="active" optional="hide"/>
      </list>
    </field>
  </record>

  <!-- Formvy -->
  <record id="view_clio_job_profile_form" model="ir.ui.view">
    <field name="name">clio.job.profile.form</field>
    <field name="model">clio.job.profile</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group string="Kontakt">
            <field name="partner_id"/>
            <field name="report_email" placeholder="Lämna tomt → används partner-e-posten"/>
            <field name="active"/>
          </group>

          <group string="Profil">
            <field name="role" placeholder="Nuvarande jobbtitel eller roll"/>
            <field name="seniority" placeholder='T.ex. "Senior / Executive"'/>
            <field name="geography" placeholder='T.ex. "Stockholm"'/>
            <field name="hybrid_ok"/>
          </group>

          <notebook>
            <page string="Bakgrund &amp; Utbildning">
              <group string="Karriärhistorik" col="1">
                <field name="background"
                       placeholder="En post per rad"
                       nolabel="1"/>
              </group>
              <group string="Utbildning" col="1">
                <field name="education"
                       placeholder="En post per rad"
                       nolabel="1"/>
              </group>
            </page>

            <page string="Bevakningsinställningar">
              <group string="Målroller" col="1">
                <field name="target_roles"
                       placeholder="En roll per rad"
                       nolabel="1"/>
              </group>
              <group string="Signalnyckelord" col="1">
                <field name="signal_keywords"
                       placeholder="Ett nyckelord per rad (t.ex. ny GD, förvärv)"
                       nolabel="1"/>
              </group>
            </page>

            <page string="Matchningshistorik">
              <field name="match_ids" nolabel="1">
                <list create="false" delete="false">
                  <field name="sent_at" string="Skickad"/>
                  <field name="article_title" string="Rubrik"/>
                  <field name="signal_type" string="Signaltyp"/>
                  <field name="match_score" string="Poäng"/>
                  <field name="recommended_action" string="Åtgärd"/>
                  <field name="article_url" string="URL"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Menypost -->
  <record id="action_clio_job_profile" model="ir.actions.act_window">
    <field name="name">Clio Job — Profiler</field>
    <field name="res_model">clio.job.profile</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>

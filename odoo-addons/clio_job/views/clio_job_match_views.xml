<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Listvy (admin: alla matchningar) -->
  <record id="view_clio_job_match_tree" model="ir.ui.view">
    <field name="name">clio.job.match.list</field>
    <field name="model">clio.job.match</field>
    <field name="arch" type="xml">
      <list create="false">
        <field name="sent_at" string="Sent"/>
        <field name="profile_id" string="Candidate"/>
        <field name="article_title" string="Title"/>
        <field name="signal_type" string="Signal Type"/>
        <field name="match_score" string="Score"/>
        <field name="recommended_action" string="Action"/>
      </list>
    </field>
  </record>

  <!-- Formvy -->
  <record id="view_clio_job_match_form" model="ir.ui.view">
    <field name="name">clio.job.match.form</field>
    <field name="model">clio.job.match</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="profile_id"/>
            <field name="sent_at"/>
            <field name="match_score"/>
            <field name="signal_type"/>
            <field name="recommended_action"/>
            <field name="article_title"/>
            <field name="article_url" widget="url"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Menypost -->
  <record id="action_clio_job_match" model="ir.actions.act_window">
    <field name="name">Clio Job — Match History</field>
    <field name="res_model">clio.job.match</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>

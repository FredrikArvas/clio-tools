<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_examensbyran_funeral_cost_component_list" model="ir.ui.view">
            <field name="name">examensbyran.funeral.cost.component.list</field>
            <field name="model">examensbyran.funeral.cost.component</field>
            <field name="arch" type="xml">
                <list string="Kostnadskomponenter">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="category"/>
                    <field name="cost_min" widget="monetary"/>
                    <field name="cost_typical" widget="monetary"/>
                    <field name="cost_max" widget="monetary"/>
                    <field name="is_optional"/>
                </list>
            </field>
        </record>

        <record id="view_examensbyran_funeral_cost_component_form" model="ir.ui.view">
            <field name="name">examensbyran.funeral.cost.component.form</field>
            <field name="model">examensbyran.funeral.cost.component</field>
            <field name="arch" type="xml">
                <form string="Kostnadskomponent">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Komponentnamn"/></h1>
                        </div>
                        <group>
                            <group string="Klassificering">
                                <field name="category"/>
                                <field name="sequence"/>
                                <field name="is_optional"/>
                                <field name="active"/>
                            </group>
                            <group string="Kostnader (SEK)">
                                <field name="cost_min" widget="monetary"/>
                                <field name="cost_typical" widget="monetary"/>
                                <field name="cost_max" widget="monetary"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_examensbyran_funeral_cost_component_search" model="ir.ui.view">
            <field name="name">examensbyran.funeral.cost.component.search</field>
            <field name="model">examensbyran.funeral.cost.component</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="category"/>
                    <filter string="Obligatoriska" name="filter_required"
                            domain="[('is_optional', '=', False)]"/>
                    <filter string="Valfria" name="filter_optional"
                            domain="[('is_optional', '=', True)]"/>
                    <group expand="1" string="Gruppera efter">
                        <filter string="Kategori" name="group_category"
                                context="{'group_by': 'category'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_examensbyran_funeral_cost_component_list" model="ir.actions.act_window">
            <field name="name">Kostnadskomponenter</field>
            <field name="res_model">examensbyran.funeral.cost.component</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id"
                   ref="view_examensbyran_funeral_cost_component_search"/>
        </record>
    </data>
</odoo>

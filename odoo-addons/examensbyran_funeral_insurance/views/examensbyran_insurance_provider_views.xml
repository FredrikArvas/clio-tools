<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_examensbyran_insurance_provider_list" model="ir.ui.view">
            <field name="name">examensbyran.insurance.provider.list</field>
            <field name="model">examensbyran.insurance.provider</field>
            <field name="arch" type="xml">
                <list string="Försäkringsaktörer">
                    <field name="name"/>
                    <field name="provider_type"/>
                    <field name="product_count"/>
                    <field name="website" widget="url"/>
                </list>
            </field>
        </record>

        <record id="view_examensbyran_insurance_provider_form" model="ir.ui.view">
            <field name="name">examensbyran.insurance.provider.form</field>
            <field name="model">examensbyran.insurance.provider</field>
            <field name="arch" type="xml">
                <form string="Försäkringsaktör">
                    <sheet>
                        <field name="logo" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Namn på aktör"/></h1>
                        </div>
                        <group>
                            <group string="Grunddata">
                                <field name="provider_type"/>
                                <field name="active"/>
                            </group>
                            <group string="Kontakt">
                                <field name="website" widget="url"/>
                                <field name="phone" widget="phone"/>
                                <field name="email" widget="email"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Beskrivning">
                                <field name="description" widget="html"/>
                            </page>
                            <page string="Produkter">
                                <field name="product_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="product_type"/>
                                        <field name="coverage_amount" widget="monetary"/>
                                        <field name="premium_amount" widget="monetary"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Anteckningar">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_examensbyran_insurance_provider_search" model="ir.ui.view">
            <field name="name">examensbyran.insurance.provider.search</field>
            <field name="model">examensbyran.insurance.provider</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="provider_type"/>
                    <filter string="Försäkringsbolag" name="filter_insurance"
                            domain="[('provider_type', '=', 'insurance_company')]"/>
                    <filter string="Fackförbund" name="filter_union"
                            domain="[('provider_type', '=', 'union')]"/>
                    <group expand="0" string="Gruppera efter">
                        <filter string="Typ" name="group_type"
                                context="{'group_by': 'provider_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_examensbyran_insurance_provider_list" model="ir.actions.act_window">
            <field name="name">Försäkringsaktörer</field>
            <field name="res_model">examensbyran.insurance.provider</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_examensbyran_insurance_provider_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Skapa din första försäkringsaktör
                </p>
                <p>
                    Lägg till de försäkringsbolag och fackförbund som erbjuder begravningsförsäkring.
                </p>
            </field>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_examensbyran_funeral_assessment_list" model="ir.ui.view">
            <field name="name">examensbyran.funeral.assessment.list</field>
            <field name="model">examensbyran.funeral.assessment</field>
            <field name="arch" type="xml">
                <list string="Begravningsförsäkring — Skattningar"
                      decoration-success="state == 'completed' and coverage_gap == 0"
                      decoration-warning="state == 'completed' and coverage_gap > 0 and coverage_gap &lt; 10000"
                      decoration-danger="state == 'completed' and coverage_gap >= 10000">
                    <field name="create_date"/>
                    <field name="partner_id"/>
                    <field name="estimated_cost_typical" widget="monetary"/>
                    <field name="known_coverage" widget="monetary"/>
                    <field name="coverage_gap" widget="monetary"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'completed'"
                           decoration-info="state == 'followup'"/>
                </list>
            </field>
        </record>

        <record id="view_examensbyran_funeral_assessment_form" model="ir.ui.view">
            <field name="name">examensbyran.funeral.assessment.form</field>
            <field name="model">examensbyran.funeral.assessment</field>
            <field name="arch" type="xml">
                <form string="Begravningsförsäkring — Skattning">
                    <header>
                        <button name="action_generate_report" type="object"
                                string="Generera rapport" class="oe_highlight"
                                invisible="state != 'draft'"/>
                        <button name="action_request_followup" type="object"
                                string="Begär uppföljning"
                                invisible="state != 'completed'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="display_name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Kontakt">
                                <field name="partner_id"/>
                            </group>
                            <group string="Skapad">
                                <field name="create_date" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Försäkringssituation">
                                <group>
                                    <group string="Hemförsäkring">
                                        <field name="has_home_insurance"/>
                                        <field name="home_insurance_provider"
                                               invisible="not has_home_insurance"/>
                                    </group>
                                    <group string="Livförsäkring">
                                        <field name="has_life_insurance"/>
                                        <field name="life_insurance_provider"
                                               invisible="not has_life_insurance"/>
                                        <field name="life_insurance_amount" widget="monetary"
                                               invisible="not has_life_insurance"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Fackförbund">
                                        <field name="has_union_membership"/>
                                        <field name="union_name"
                                               invisible="not has_union_membership"/>
                                    </group>
                                    <group string="Begravningsförsäkring">
                                        <field name="has_funeral_insurance"/>
                                        <field name="funeral_insurance_amount" widget="monetary"
                                               invisible="not has_funeral_insurance"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Preferenser">
                                <group>
                                    <field name="preferred_funeral_type"/>
                                    <field name="preferred_ceremony_size"/>
                                </group>
                            </page>
                            <page string="Rapport" invisible="state == 'draft'">
                                <group>
                                    <group string="Beräknad kostnad">
                                        <field name="estimated_cost_min" widget="monetary"
                                               readonly="1"/>
                                        <field name="estimated_cost_typical" widget="monetary"
                                               readonly="1"/>
                                        <field name="estimated_cost_max" widget="monetary"
                                               readonly="1"/>
                                    </group>
                                    <group string="Försäkringsskydd">
                                        <field name="known_coverage" widget="monetary"
                                               readonly="1"/>
                                        <field name="coverage_gap" widget="monetary"
                                               readonly="1"/>
                                    </group>
                                </group>
                                <separator string="Rekommendation"/>
                                <field name="recommendation" widget="html" readonly="1"/>
                            </page>
                            <page string="Uppföljning" invisible="state != 'followup'">
                                <group>
                                    <field name="wants_followup"/>
                                    <field name="followup_email" widget="email"/>
                                    <field name="followup_phone" widget="phone"/>
                                </group>
                                <separator string="Anteckningar"/>
                                <field name="followup_notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_examensbyran_funeral_assessment_search" model="ir.ui.view">
            <field name="name">examensbyran.funeral.assessment.search</field>
            <field name="model">examensbyran.funeral.assessment</field>
            <field name="arch" type="xml">
                <search>
                    <field name="partner_id"/>
                    <filter string="Utkast" name="filter_draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Genomförda" name="filter_completed"
                            domain="[('state', '=', 'completed')]"/>
                    <filter string="Intresseanmälda" name="filter_followup"
                            domain="[('state', '=', 'followup')]"/>
                    <group expand="0" string="Gruppera efter">
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_examensbyran_funeral_assessment_list" model="ir.actions.act_window">
            <field name="name">Skattningar</field>
            <field name="res_model">examensbyran.funeral.assessment</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id"
                   ref="view_examensbyran_funeral_assessment_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Skapa din första skattning
                </p>
                <p>
                    Kartlägg en persons försäkringssituation och generera en personlig rapport.
                </p>
            </field>
        </record>
    </data>
</odoo>

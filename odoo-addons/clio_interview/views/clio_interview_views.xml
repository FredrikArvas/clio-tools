<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Mallar ─────────────────────────────────────────────────────────── -->

  <record id="view_clio_interview_template_list" model="ir.ui.view">
    <field name="name">clio.interview.template.list</field>
    <field name="model">clio.interview.template</field>
    <field name="arch" type="xml">
      <list string="Intervjumallar">
        <field name="name"             string="Mallnamn"/>
        <field name="subject"          string="Ämne"/>
        <field name="opening_question" string="Öppningsfråga"/>
        <field name="active"           string="Aktiv" widget="boolean"/>
      </list>
    </field>
  </record>

  <record id="view_clio_interview_template_form" model="ir.ui.view">
    <field name="name">clio.interview.template.form</field>
    <field name="model">clio.interview.template</field>
    <field name="arch" type="xml">
      <form string="Intervjumall">
        <sheet>
          <group>
            <field name="name"    string="Mallnamn"/>
            <field name="subject" string="Ämne"/>
            <field name="active"  string="Aktiv" widget="boolean_toggle"/>
          </group>
          <group string="Öppningsfråga">
            <field name="opening_question" nolabel="1" widget="text"
                   style="min-height: 120px;"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_clio_interview_templates" model="ir.actions.act_window">
    <field name="name">Intervjumallar</field>
    <field name="res_model">clio.interview.template</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- ── Sessioner ──────────────────────────────────────────────────────── -->

  <record id="view_clio_interview_session_list" model="ir.ui.view">
    <field name="name">clio.interview.session.list</field>
    <field name="model">clio.interview.session</field>
    <field name="arch" type="xml">
      <list string="Intervjusessioner"
            decoration-success="status == 'active'"
            decoration-muted="status == 'stopped'">
        <field name="created_at"        string="Startad"     optional="show"/>
        <field name="partner_id"        string="Deltagare"/>
        <field name="participant_email" string="E-post"      optional="show"/>
        <field name="account_key"       string="Konto"       optional="show"/>
        <field name="status"            string="Status"      widget="badge"/>
        <field name="close_at"          string="Stängs"      optional="show"/>
        <field name="updated_at"        string="Senaste"     optional="hide"/>
      </list>
    </field>
  </record>

  <record id="view_clio_interview_session_form" model="ir.ui.view">
    <field name="name">clio.interview.session.form</field>
    <field name="model">clio.interview.session</field>
    <field name="arch" type="xml">
      <form string="Intervjusession">
        <header>
          <button name="action_load_messages" type="object"
                  string="Ladda dialog" class="btn-primary"/>
          <button name="action_stop" type="object"
                  string="Avsluta session" class="btn-warning"
                  invisible="status == 'stopped'"
                  confirm="Avsluta intervjusessionen med denna deltagare?"/>
          <field name="status" widget="statusbar"
                 statusbar_visible="active,stopped"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="partner_id"        string="Deltagare"
                     options="{'no_create': True}"/>
              <field name="participant_email" string="E-post" readonly="1"/>
              <field name="account_key"       string="Konto"/>
            </group>
            <group>
              <field name="created_at" string="Startad"          readonly="1"/>
              <field name="updated_at" string="Uppdaterad"       readonly="1"/>
              <field name="close_at"   string="Stäng automatiskt"/>
            </group>
          </group>

          <!-- Dialog -->
          <group string="Dialog">
            <field name="message_ids" nolabel="1" invisible="not message_ids">
              <list decoration-info="direction == 'outbound'"
                    decoration-success="direction == 'inbound'">
                <field name="date_received" string="Datum"/>
                <field name="direction"     string="Riktning" column_invisible="1"/>
                <field name="sender"        string="Avsändare" optional="hide"/>
                <field name="body"          string="Meddelande"/>
              </list>
            </field>
            <div invisible="status == 'stopped'" style="margin-top: 8px;">
              <field name="compose_body" nolabel="1" widget="text"
                     style="min-height: 80px;"
                     placeholder="Skriv nästa fråga eller meddelande..."/>
              <div class="o_row" style="margin-top: 6px;">
                <button name="action_send_message" type="object"
                        string="Skicka" class="btn-primary"
                        invisible="not compose_body"/>
              </div>
            </div>
          </group>

          <!-- Sammanfattning -->
          <group string="Sammanfattning">
            <field name="summary_prompt" nolabel="1" widget="text"
                   style="min-height: 60px;"
                   placeholder="Lämna tom för standardsammanfattning — eller beskriv vad du vill ha ut av svaren."/>
            <div class="o_row" style="margin: 6px 0 10px;">
              <button name="action_summarize" type="object"
                      string="Begär sammanfattning" class="btn-secondary"
                      confirm="Hämtar dialog och skickar till Claude. Fortsätta?"/>
            </div>
            <field name="summary_text" nolabel="1" widget="text" readonly="1"
                   invisible="not summary_text"
                   style="font-family: monospace; white-space: pre-wrap; background: #f7f2e8; padding: 8px; border-radius: 4px;"/>
          </group>

        </sheet>
      </form>
    </field>
  </record>

  <record id="action_clio_interview_sessions" model="ir.actions.act_window">
    <field name="name">Intervjusessioner</field>
    <field name="res_model">clio.interview.session</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- ── Starta intervju-wizard ─────────────────────────────────────────── -->

  <record id="view_clio_interview_start_wizard" model="ir.ui.view">
    <field name="name">clio.interview.start.wizard.form</field>
    <field name="model">clio.interview.start.wizard</field>
    <field name="arch" type="xml">
      <form string="Starta intervju">
        <sheet>
          <group string="Mall (valfri)">
            <field name="template_id" string="Välj mall"
                   options="{'no_create': True}"/>
          </group>
          <group string="Eller ange manuellt">
            <field name="custom_subject" string="Ämne"
                   invisible="template_id != False"
                   placeholder="T.ex. Karriärsamtal Q2 2026"/>
            <field name="custom_question" string="Öppningsfråga" widget="text"
                   invisible="template_id != False"
                   style="min-height: 80px;"/>
          </group>
          <group string="Deltagare">
            <field name="partner_ids" nolabel="1"
                   widget="many2many_tags"
                   options="{'no_create': True}"
                   placeholder="Sök och välj kontakter..."/>
          </group>
          <group>
            <group>
              <field name="account_key" string="Konto"/>
            </group>
            <group>
              <field name="close_at" string="Stäng automatiskt"
                     placeholder="Lämna tom för manuell stängning"/>
            </group>
          </group>
          <div class="o_row" style="margin: 8px 0;">
            <button name="action_start" type="object"
                    string="Skicka öppningsfråga" class="btn-primary"/>
          </div>
          <group string="Resultat" invisible="not result_text">
            <field name="result_text" nolabel="1" widget="text" readonly="1"
                   style="font-family: monospace; white-space: pre-wrap;"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_clio_interview_start_wizard" model="ir.actions.act_window">
    <field name="name">Starta intervju</field>
    <field name="res_model">clio.interview.start.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

</odoo>

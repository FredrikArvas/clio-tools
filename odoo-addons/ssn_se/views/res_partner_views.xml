<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Lägg till personnummer-fält på res.partner-formuläret -->
  <record id="view_partner_form_ssn_se" model="ir.ui.view">
    <field name="name">res.partner.form.ssn_se</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">

      <!-- Placera personnummer direkt under namnfältet -->
      <field name="name" position="after">
        <field name="personnummer" placeholder="YYYYMMDD-NNNN"/>
      </field>

    </field>
  </record>

</odoo>

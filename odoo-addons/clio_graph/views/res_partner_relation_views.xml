<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Listvy: alla relationer med Neo4j-synkstatus -->
  <record id="view_clio_graph_relation_list" model="ir.ui.view">
    <field name="name">clio.graph.relation.list</field>
    <field name="model">res.partner.relation</field>
    <field name="arch" type="xml">
      <list string="Nätverksrelationer">
        <field name="left_partner_id"/>
        <field name="type_id"/>
        <field name="right_partner_id"/>
        <field name="date_start"/>
        <field name="date_end"/>
        <field name="sync_to_neo4j"/>
        <field name="neo4j_synced_at"/>
      </list>
    </field>
  </record>

  <!-- Formulärvy: standalone med Neo4j-sektion -->
  <record id="view_clio_graph_relation_form" model="ir.ui.view">
    <field name="name">clio.graph.relation.form</field>
    <field name="model">res.partner.relation</field>
    <field name="arch" type="xml">
      <form string="Nätverksrelation">
        <sheet>
          <group>
            <field name="left_partner_id"/>
            <field name="type_id"/>
            <field name="right_partner_id"/>
            <field name="date_start"/>
            <field name="date_end"/>
          </group>
          <group string="Neo4j Synk">
            <field name="sync_to_neo4j"/>
            <field name="neo4j_synced_at"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action: öppnar relationslistvy -->
  <record id="action_clio_graph_relations" model="ir.actions.act_window">
    <field name="name">Nätverksrelationer</field>
    <field name="res_model">res.partner.relation</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>

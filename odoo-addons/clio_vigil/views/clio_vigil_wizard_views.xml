<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Wizard: Ändra tillstånd ────────────────────────────────────────── -->
  <record id="view_clio_vigil_set_state_wizard_form" model="ir.ui.view">
    <field name="name">clio.vigil.set.state.wizard.form</field>
    <field name="model">clio.vigil.set.state.wizard</field>
    <field name="arch" type="xml">
      <form string="Ändra tillstånd">
        <group>
          <field name="new_state" string="Nytt tillstånd"/>
          <field name="item_count" string="Valda objekt" readonly="1"/>
        </group>
        <group string="Objekt som påverkas">
          <field name="item_ids" string="" nolabel="1"
                 widget="many2many_tags" readonly="1"/>
        </group>
        <footer>
          <button name="action_apply" type="object"
                  string="Tillämpa" class="btn-primary"/>
          <button string="Avbryt" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- ── Server action (bunden till clio.vigil.item listvy) ────────────── -->
  <record id="action_clio_vigil_set_state" model="ir.actions.server">
    <field name="name">Ändra tillstånd</field>
    <field name="model_id"         ref="model_clio_vigil_item"/>
    <field name="binding_model_id" ref="model_clio_vigil_item"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Ändra tillstånd',
    'res_model': 'clio.vigil.set.state.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'default_item_ids': env.context.get('active_ids', []),
    },
}
    </field>
  </record>

</odoo>

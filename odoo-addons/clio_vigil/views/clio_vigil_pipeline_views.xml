<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Action ─────────────────────────────────────────────────────────── -->
  <record id="action_clio_vigil_pipeline" model="ir.actions.act_window">
    <field name="name">Pipeline</field>
    <field name="res_model">clio.vigil.pipeline</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
  </record>

  <!-- ── Formulärvy (kontrollpanel) ─────────────────────────────────────── -->
  <record id="view_clio_vigil_pipeline_form" model="ir.ui.view">
    <field name="name">clio.vigil.pipeline.form</field>
    <field name="model">clio.vigil.pipeline</field>
    <field name="arch" type="xml">
      <form string="Pipeline — clio-vigil" create="false" delete="false">
        <sheet>

          <!-- Status från heartbeat -->
          <group string="Agentstatus">
            <group>
              <field name="heartbeat_status"   string="Status"           widget="badge"
                     decoration-success="heartbeat_status == 'ok'"
                     decoration-warning="heartbeat_status == 'warning'"
                     decoration-danger="heartbeat_status == 'error'"/>
              <field name="heartbeat_last_run" string="Senaste körning"  readonly="1"/>
              <field name="heartbeat_message"  string="Meddelande"       readonly="1"/>
            </group>
            <group>
              <field name="last_step"          string="Senaste steg"     readonly="1"/>
              <field name="last_status"        string="Resultat"         widget="badge"
                     decoration-success="last_status == 'done'"
                     decoration-warning="last_status == 'running'"
                     decoration-danger="last_status == 'error'"/>
              <field name="last_triggered"     string="Triggrad av"      readonly="1"/>
              <field name="last_completed"     string="Avslutad"         readonly="1"/>
            </group>
          </group>

          <separator string="Pipeline-steg"/>

          <!-- Stegknappar -->
          <div class="row g-2 mt-1 mb-3">
            <div class="col-6 col-md-4">
              <button name="action_run" type="object"
                      class="btn btn-secondary w-100"
                      string="&#128225; Samla in"
                      confirm="Starta insamling (collect + filter) för alla domäner?"/>
            </div>
            <div class="col-6 col-md-4">
              <button name="action_transcribe" type="object"
                      class="btn btn-secondary w-100"
                      string="&#127897; Transkribera"
                      confirm="Starta transkription av objekt i kö?"/>
            </div>
            <div class="col-6 col-md-4">
              <button name="action_summarize" type="object"
                      class="btn btn-secondary w-100"
                      string="&#9997; Summera"
                      confirm="Starta summering med Claude?"/>
            </div>
            <div class="col-6 col-md-4">
              <button name="action_index" type="object"
                      class="btn btn-secondary w-100"
                      string="&#128218; Indexera (RAG)"
                      confirm="Starta RAG-indexering i Qdrant?"/>
            </div>
            <div class="col-6 col-md-4">
              <button name="action_digest" type="object"
                      class="btn btn-secondary w-100"
                      string="&#128231; Digest-mail"
                      confirm="Skicka daglig digest till prenumeranter?"/>
            </div>
            <div class="col-6 col-md-4">
              <button name="action_seed" type="object"
                      class="btn btn-secondary w-100"
                      string="&#127758; Importera källor"
                      confirm="Importera YAML-källkonfiguration till Odoo?"/>
            </div>
          </div>

          <separator string="Snabbkörning"/>

          <div class="row g-2 mb-2">
            <div class="col-12 col-md-6">
              <button name="action_full" type="object"
                      class="btn btn-primary w-100 oe_highlight"
                      string="&#9889; Kör full pipeline"
                      confirm="Kör hela pipeline: samla in → transkribera → summera → indexera → digest?"/>
            </div>
            <div class="col-12 col-md-6">
              <button name="action_recompute" type="object"
                      class="btn btn-secondary w-100"
                      string="&#128202; Räkna om prioriteter"
                      confirm="Räkna om priority_score för alla objekt (inkl. tidsfaktor)?"/>
            </div>
          </div>

        </sheet>
      </form>
    </field>
  </record>

</odoo>

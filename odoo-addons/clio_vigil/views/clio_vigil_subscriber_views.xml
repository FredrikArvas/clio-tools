<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Actions (definieras först så att form-vyn kan referera dem) ──────── -->

  <record id="action_clio_vigil_subscriber" model="ir.actions.act_window">
    <field name="name">Prenumeranter</field>
    <field name="res_model">clio.vigil.subscriber</field>
    <field name="view_mode">list,kanban,form,graph</field>
    <field name="context">{'search_default_active': 1}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Inga prenumeranter ännu.
      </p>
      <p>
        Skapa en prenumerant kopplad till en kontakt och välj
        vilka domäner (UFO/UAP, AI-modeller) de ska följa.
      </p>
    </field>
  </record>

  <record id="action_clio_vigil_delivery_sub" model="ir.actions.act_window">
    <field name="name">Leveranser</field>
    <field name="res_model">clio.vigil.delivery</field>
    <field name="view_mode">list,graph</field>
    <field name="domain">[('subscriber_id','=',active_id)]</field>
    <field name="context">{'default_subscriber_id': active_id}</field>
  </record>

  <!-- ── Kanbanvy prenumeranter ────────────────────────────────────────── -->
  <record id="view_clio_vigil_subscriber_kanban" model="ir.ui.view">
    <field name="name">clio.vigil.subscriber.kanban</field>
    <field name="model">clio.vigil.subscriber</field>
    <field name="arch" type="xml">
      <kanban>
        <field name="partner_id"/>
        <field name="effective_email"/>
        <field name="follows_ufo"/>
        <field name="follows_ai"/>
        <field name="delivery_count"/>
        <field name="active"/>
        <templates>
          <t t-name="card">
            <div class="fw-bold fs-6"><field name="partner_id"/></div>
            <div class="text-muted small"><field name="effective_email"/></div>
            <div class="mt-1">
              <span t-if="record.follows_ufo.raw_value"
                    class="badge text-bg-warning me-1">UFO/UAP</span>
              <span t-if="record.follows_ai.raw_value"
                    class="badge text-bg-info">AI</span>
            </div>
            <div class="text-muted small mt-1">
              <field name="delivery_count"/> leveranser
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- ── Diagramvy prenumeranter ────────────────────────────────────────── -->
  <record id="view_clio_vigil_subscriber_graph" model="ir.ui.view">
    <field name="name">clio.vigil.subscriber.graph</field>
    <field name="model">clio.vigil.subscriber</field>
    <field name="arch" type="xml">
      <graph string="Prenumeranter per domän" type="bar">
        <field name="follows_ufo" type="row"/>
        <field name="follows_ai"  type="col"/>
      </graph>
    </field>
  </record>

  <!-- ── Diagramvy leveranser ───────────────────────────────────────────── -->
  <record id="view_clio_vigil_delivery_graph" model="ir.ui.view">
    <field name="name">clio.vigil.delivery.graph</field>
    <field name="model">clio.vigil.delivery</field>
    <field name="arch" type="xml">
      <graph string="Leveranser över tid" type="bar">
        <field name="digest_date"   type="row"/>
        <field name="subscriber_id" type="col"/>
      </graph>
    </field>
  </record>

  <!-- ── Listvy prenumeranter ───────────────────────────────────────────── -->
  <record id="view_clio_vigil_subscriber_list" model="ir.ui.view">
    <field name="name">clio.vigil.subscriber.list</field>
    <field name="model">clio.vigil.subscriber</field>
    <field name="arch" type="xml">
      <list string="Prenumeranter">
        <field name="partner_id"       string="Kontakt"/>
        <field name="effective_email"  string="E-post"/>
        <field name="follows_ufo"      string="UFO/UAP"     widget="boolean_toggle"/>
        <field name="follows_ai"       string="AI-modeller" widget="boolean_toggle"/>
        <field name="delivery_count"   string="Leveranser"/>
        <field name="active"           string="Aktiv"       widget="boolean_toggle" optional="show"/>
      </list>
    </field>
  </record>

  <!-- ── Formulärvy ─────────────────────────────────────────────────────── -->
  <record id="view_clio_vigil_subscriber_form" model="ir.ui.view">
    <field name="name">clio.vigil.subscriber.form</field>
    <field name="model">clio.vigil.subscriber</field>
    <field name="arch" type="xml">
      <form string="Prenumerant">
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="%(action_clio_vigil_delivery_sub)d"
                    type="action"
                    class="oe_stat_button"
                    icon="fa-envelope-o"
                    context="{'search_default_subscriber_id': id}">
              <field name="delivery_count" widget="statinfo" string="Leveranser"/>
            </button>
          </div>
          <field name="active" widget="boolean_toggle" class="float-end"/>
          <group>
            <group string="Kontakt">
              <field name="partner_id"      string="Kontakt"/>
              <field name="email"           string="E-post (override)"
                     placeholder="Lämna tomt = använd kontaktens e-post"/>
              <field name="effective_email" string="Effektiv e-post" readonly="1"/>
            </group>
            <group string="Domäner">
              <field name="follows_ufo" string="UFO/UAP"/>
              <field name="follows_ai"  string="AI-modeller"/>
            </group>
          </group>

          <notebook>
            <page string="Sökord" name="keywords">
              <field name="keyword_ids" string="">
                <list editable="bottom">
                  <field name="keyword" string="Sökord"/>
                  <field name="weight"  string="Vikt"/>
                  <field name="domain"  string="Domän"/>
                </list>
              </field>
            </page>
            <page string="Leveranser" name="deliveries">
              <field name="delivery_ids" readonly="1" string="">
                <list>
                  <field name="delivered_at" string="Skickad"/>
                  <field name="item_id"      string="Objekt"/>
                  <field name="digest_date"  string="Digestdatum"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ── Sökvy ──────────────────────────────────────────────────────────── -->
  <record id="view_clio_vigil_subscriber_search" model="ir.ui.view">
    <field name="name">clio.vigil.subscriber.search</field>
    <field name="model">clio.vigil.subscriber</field>
    <field name="arch" type="xml">
      <search string="Sök prenumeranter">
        <field name="partner_id" string="Kontakt"/>
        <filter name="active"      string="Aktiva"       domain="[('active','=',True)]"/>
        <filter name="follows_ufo" string="UFO/UAP"      domain="[('follows_ufo','=',True)]"/>
        <filter name="follows_ai"  string="AI-modeller"  domain="[('follows_ai','=',True)]"/>
      </search>
    </field>
  </record>

  <!-- ── Listvy leveranser (standalone) ────────────────────────────────── -->
  <record id="view_clio_vigil_delivery_list" model="ir.ui.view">
    <field name="name">clio.vigil.delivery.list</field>
    <field name="model">clio.vigil.delivery</field>
    <field name="arch" type="xml">
      <list string="Leveranser" default_order="delivered_at desc">
        <field name="delivered_at"  string="Skickad"/>
        <field name="subscriber_id" string="Prenumerant"/>
        <field name="item_id"       string="Objekt"/>
        <field name="digest_date"   string="Digestdatum" optional="show"/>
      </list>
    </field>
  </record>

</odoo>

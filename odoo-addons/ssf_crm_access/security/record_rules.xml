<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            SDF-admin: res.partner — read-only
            Ser: sin SDF-partner (direkt id-match) + alla partners vars
            ssfta_sdf_id pekar på deras förvaltade SDF.
        -->
        <record id="rule_sdf_admin_partner_read" model="ir.rule">
            <field name="name">SDF-admin: sin SDF + föreningar + utövare</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_ssf_sdf_admin'))]"/>
            <field name="domain_force">
                ['|',
                  ('id', '=', user.ssfta_managed_partner_id.id),
                  ('ssfta_sdf_id', '=', user.ssfta_managed_partner_id.id)
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            Klubbadmin: res.partner — read-only
            Ser: sin förening (direkt id-match) + alla person-partners vars
            ssfta_club_id pekar på deras förvaltade förening.
        -->
        <record id="rule_club_admin_partner_read" model="ir.rule">
            <field name="name">Klubbadmin: sin förening + utövare</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('group_ssf_club_admin'))]"/>
            <field name="domain_force">
                ['|',
                  ('id', '=', user.ssfta_managed_partner_id.id),
                  ('ssfta_club_id', '=', user.ssfta_managed_partner_id.id)
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            SF-admin: ingen begränsande record rule.
            SF-admins ser hela partnerdatabasen via standardrättigheter.
        -->

    </data>
</odoo>

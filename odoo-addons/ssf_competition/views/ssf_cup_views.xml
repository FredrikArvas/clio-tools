<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ssf_cup_list" model="ir.ui.view">
        <field name="name">ssf.cup.list</field>
        <field name="model">ssf.cup</field>
        <field name="arch" type="xml">
            <list string="Tävlingsserier" create="false" edit="false" delete="false">
                <field name="name" string="Namn"/>
                <field name="sector_id" string="Gren"/>
                <field name="season_id" string="Säsong"/>
                <field name="geographical_scope" string="Räckvidd"/>
                <field name="organizer_id" string="Arrangör"/>
                <field name="email" string="E-post"/>
            </list>
        </field>
    </record>

    <record id="view_ssf_cup_form" model="ir.ui.view">
        <field name="name">ssf.cup.form</field>
        <field name="model">ssf.cup</field>
        <field name="arch" type="xml">
            <form string="Tävlingsserie" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sector_id" readonly="1" string="Gren"/>
                            <field name="season_id" readonly="1" string="Säsong"/>
                            <field name="geographical_scope" readonly="1" string="Räckvidd"/>
                        </group>
                        <group>
                            <field name="organizer_id" readonly="1" string="Arrangör"/>
                            <field name="email" readonly="1" string="E-post"/>
                            <field name="ssfta_id" readonly="1" string="SSFTA ID"/>
                        </group>
                    </group>
                    <group string="Beskrivning">
                        <field name="description" nolabel="1" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Evenemang" name="events">
                            <field name="event_ids" readonly="1">
                                <list create="false" edit="false" delete="false"
                                      default_order="start_date">
                                    <field name="name" string="Namn"/>
                                    <field name="start_date" string="Datum"/>
                                    <field name="city" string="Ort"/>
                                    <field name="event_status" string="Status"/>
                                    <field name="competition_count" string="Tävlingar"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ssf_cup_search" model="ir.ui.view">
        <field name="name">ssf.cup.search</field>
        <field name="model">ssf.cup</field>
        <field name="arch" type="xml">
            <search string="Sök serier">
                <field name="name" string="Namn"/>
                <field name="sector_id" string="Gren"/>
                <field name="season_id" string="Säsong"/>
                <field name="organizer_id" string="Arrangör"/>
                <group expand="0" string="Gruppera efter">
                    <filter string="Gren" name="group_sector"
                            context="{'group_by': 'sector_id'}"/>
                    <filter string="Säsong" name="group_season"
                            context="{'group_by': 'season_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_ssf_cup_kanban" model="ir.ui.view">
        <field name="name">ssf.cup.kanban</field>
        <field name="model">ssf.cup</field>
        <field name="arch" type="xml">
            <kanban default_order="name" create="false">
                <field name="name"/>
                <field name="sector_id"/>
                <field name="season_id"/>
                <field name="geographical_scope"/>
                <field name="organizer_id"/>
                <field name="email"/>
                <templates>
                    <t t-name="card">
                        <div class="fw-bold fs-5 mb-1">
                            <t t-esc="record.name.value"/>
                        </div>
                        <div class="text-muted small mb-1">
                            <t t-esc="record.sector_id.value"/>
                            <t t-if="record.season_id.value">
                                &amp;nbsp;·&amp;nbsp;<t t-esc="record.season_id.value"/>
                            </t>
                        </div>
                        <t t-if="record.geographical_scope.value">
                            <span class="badge text-bg-secondary small">
                                <t t-esc="record.geographical_scope.value"/>
                            </span>
                        </t>
                        <t t-if="record.organizer_id.value">
                            <div class="text-muted small mt-1">
                                <t t-esc="record.organizer_id.value"/>
                            </div>
                        </t>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ssf_cup_graph" model="ir.ui.view">
        <field name="name">ssf.cup.graph</field>
        <field name="model">ssf.cup</field>
        <field name="arch" type="xml">
            <graph string="Tävlingsserier" type="bar">
                <field name="sector_id" type="row" string="Gren"/>
                <field name="season_id" type="col" string="Säsong"/>
            </graph>
        </field>
    </record>

    <record id="view_ssf_cup_pivot" model="ir.ui.view">
        <field name="name">ssf.cup.pivot</field>
        <field name="model">ssf.cup</field>
        <field name="arch" type="xml">
            <pivot string="Tävlingsserier" display_quantity="true">
                <field name="sector_id" type="row" string="Gren"/>
                <field name="season_id" type="col" string="Säsong"/>
            </pivot>
        </field>
    </record>

    <record id="action_ssf_cup_list" model="ir.actions.act_window">
        <field name="name">Tävlingsserier</field>
        <field name="res_model">ssf.cup</field>
        <field name="view_mode">list,kanban,graph,pivot,form</field>
        <field name="context">{"create": false}</field>
    </record>
</odoo>

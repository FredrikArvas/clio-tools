<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ssf_sector_list" model="ir.ui.view">
        <field name="name">ssf.sector.list</field>
        <field name="model">ssf.sector</field>
        <field name="arch" type="xml">
            <list string="Grenar" create="false" edit="false" delete="false">
                <field name="name" string="Namn"/>
                <field name="sector_code" string="Kod"/>
                <field name="fis_sector_code" string="FIS-kod"/>
                <field name="event_count" string="Evenemang"/>
                <field name="competition_count" string="Tävlingar"/>
                <field name="hidden" string="Dold"/>
            </list>
        </field>
    </record>

    <!-- ══ KANBAN — over the top ══════════════════════════════════════════ -->
    <record id="view_ssf_sector_kanban" model="ir.ui.view">
        <field name="name">ssf.sector.kanban</field>
        <field name="model">ssf.sector</field>
        <field name="arch" type="xml">
            <kanban default_order="competition_count desc" create="false"
                    class="o_kanban_small_column">
                <field name="name"/>
                <field name="sector_code"/>
                <field name="fis_sector_code"/>
                <field name="event_count"/>
                <field name="competition_count"/>
                <field name="cs_event_count"/>
                <field name="cs_competition_count"/>
                <field name="sport_emoji"/>
                <field name="sport_color"/>
                <field name="sport_color2"/>
                <field name="hidden"/>
                <field name="gold_count"/>
                <field name="silver_count"/>
                <field name="bronze_count"/>
                <templates>
                    <t t-name="card">
                        <!-- ── Hero-header med gradient + emoji + namn ── -->
                        <div t-attf-style="
                            background: linear-gradient(145deg, #{record.sport_color.value} 0%, #{record.sport_color2.value} 100%);
                            margin: -12px -12px 0 -12px;
                            padding: 20px 16px 16px 16px;
                            border-radius: 6px 6px 0 0;
                            min-height: 110px;
                            position: relative;
                        ">
                            <!-- Kod-badge övre höger -->
                            <span style="
                                position: absolute; top: 12px; right: 12px;
                                background: rgba(255,255,255,0.18);
                                color: white;
                                font-size: 0.75rem;
                                font-weight: 700;
                                letter-spacing: 0.08em;
                                padding: 3px 10px;
                                border-radius: 20px;
                                border: 1px solid rgba(255,255,255,0.3);
                            ">
                                <t t-esc="record.sector_code.value"/>
                            </span>

                            <!-- Emoji -->
                            <div style="font-size: 3.2rem; line-height: 1; margin-bottom: 8px;">
                                <t t-esc="record.sport_emoji.value"/>
                            </div>

                            <!-- Sportnamn -->
                            <div style="
                                color: white;
                                font-size: 1.35rem;
                                font-weight: 800;
                                letter-spacing: -0.01em;
                                text-shadow: 0 1px 3px rgba(0,0,0,0.4);
                            ">
                                <t t-esc="record.name.value"/>
                            </div>
                        </div>

                        <!-- ── Stats-sektion ── -->
                        <div style="display: flex; gap: 10px; padding: 14px 0 8px 0;">

                            <!-- Evenemang -->
                            <div style="
                                flex: 1;
                                background: #F4F6F9;
                                border-radius: 8px;
                                padding: 12px 8px 10px 8px;
                                text-align: center;
                            ">
                                <!-- Innevarande säsong — stor -->
                                <div style="
                                    font-size: 2.2rem;
                                    font-weight: 900;
                                    color: #1A252F;
                                    line-height: 1;
                                ">
                                    <t t-esc="record.cs_event_count.value"/>
                                </div>
                                <div style="
                                    font-size: 0.65rem;
                                    font-weight: 700;
                                    color: #5D8AA8;
                                    text-transform: uppercase;
                                    letter-spacing: 0.07em;
                                    margin-top: 3px;
                                ">
                                    Evenemang
                                </div>
                                <!-- All-time — liten -->
                                <div style="
                                    margin-top: 6px;
                                    padding-top: 6px;
                                    border-top: 1px solid #E8ECF0;
                                    font-size: 0.72rem;
                                    color: #AAB7B8;
                                ">
                                    Totalt <t t-esc="record.event_count.value"/>
                                </div>
                            </div>

                            <!-- Tävlingar -->
                            <div style="
                                flex: 1;
                                background: #F4F6F9;
                                border-radius: 8px;
                                padding: 12px 8px 10px 8px;
                                text-align: center;
                            ">
                                <!-- Innevarande säsong — stor -->
                                <div style="
                                    font-size: 2.2rem;
                                    font-weight: 900;
                                    color: #1A252F;
                                    line-height: 1;
                                ">
                                    <t t-esc="record.cs_competition_count.value"/>
                                </div>
                                <div style="
                                    font-size: 0.65rem;
                                    font-weight: 700;
                                    color: #5D8AA8;
                                    text-transform: uppercase;
                                    letter-spacing: 0.07em;
                                    margin-top: 3px;
                                ">
                                    Tävlingar
                                </div>
                                <!-- All-time — liten -->
                                <div style="
                                    margin-top: 6px;
                                    padding-top: 6px;
                                    border-top: 1px solid #E8ECF0;
                                    font-size: 0.72rem;
                                    color: #AAB7B8;
                                ">
                                    Totalt <t t-esc="record.competition_count.value"/>
                                </div>
                            </div>
                        </div>
                        <!-- Säsongetikett -->
                        <div style="
                            text-align: center;
                            font-size: 0.65rem;
                            font-weight: 700;
                            color: #5D8AA8;
                            text-transform: uppercase;
                            letter-spacing: 0.1em;
                            padding-bottom: 8px;
                        ">&#128197; Säsong 2025/26</div>

                        <!-- ── Medaljer ── -->
                        <t t-if="record.gold_count.raw_value > 0">
                            <div style="
                                display: flex; gap: 6px; padding: 0 0 10px 0;
                                justify-content: center;
                            ">
                                <span style="
                                    font-size: 0.82rem; font-weight: 700;
                                    background: #FFFDE7; border-radius: 6px;
                                    padding: 4px 10px; color: #5D4037;
                                    border: 1px solid #F9A825;
                                ">🥇 <t t-esc="record.gold_count.value"/></span>
                                <span style="
                                    font-size: 0.82rem; font-weight: 700;
                                    background: #F5F5F5; border-radius: 6px;
                                    padding: 4px 10px; color: #424242;
                                    border: 1px solid #BDBDBD;
                                ">🥈 <t t-esc="record.silver_count.value"/></span>
                                <span style="
                                    font-size: 0.82rem; font-weight: 700;
                                    background: #FFF3E0; border-radius: 6px;
                                    padding: 4px 10px; color: #4E342E;
                                    border: 1px solid #FF8F00;
                                ">🥉 <t t-esc="record.bronze_count.value"/></span>
                            </div>
                        </t>

                        <!-- ── Footer: FIS-kod + knappar ── -->
                        <div style="
                            border-top: 1px solid #ECF0F1;
                            padding-top: 10px;
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                        ">
                            <span style="font-size: 0.72rem; color: #95A5A6;">
                                <t t-if="record.fis_sector_code.value">
                                    FIS: <t t-esc="record.fis_sector_code.value"/>
                                </t>
                            </span>
                            <div style="display: flex; gap: 6px;">
                                <button name="action_view_events" type="object"
                                        style="
                                            font-size: 0.72rem;
                                            padding: 3px 10px;
                                            border-radius: 4px;
                                            border: 1px solid #BDC3C7;
                                            background: white;
                                            cursor: pointer;
                                            color: #2C3E50;
                                        ">
                                    Evenemang →
                                </button>
                                <button name="action_view_competitions" type="object"
                                        t-attf-style="
                                            font-size: 0.72rem;
                                            padding: 3px 10px;
                                            border-radius: 4px;
                                            border: none;
                                            background: #{record.sport_color2.value};
                                            cursor: pointer;
                                            color: white;
                                            font-weight: 600;
                                        ">
                                    Tävlingar →
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ssf_sector_graph" model="ir.ui.view">
        <field name="name">ssf.sector.graph</field>
        <field name="model">ssf.sector</field>
        <field name="arch" type="xml">
            <graph string="Grenar" type="bar" stacked="0">
                <field name="name" type="row"/>
                <field name="event_count" type="measure" string="Evenemang"/>
                <field name="competition_count" type="measure" string="Tävlingar"/>
            </graph>
        </field>
    </record>

    <record id="view_ssf_sector_form" model="ir.ui.view">
        <field name="name">ssf.sector.form</field>
        <field name="model">ssf.sector</field>
        <field name="arch" type="xml">
            <form string="Gren" create="false" edit="false">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_events" type="object"
                                class="oe_stat_button" icon="fa-trophy">
                            <field name="event_count" widget="statinfo" string="Evenemang"/>
                        </button>
                        <button name="action_view_competitions" type="object"
                                class="oe_stat_button" icon="fa-flag">
                            <field name="competition_count" widget="statinfo" string="Tävlingar"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="sport_emoji" readonly="1" nolabel="1"/>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sector_code" readonly="1" string="Kod"/>
                            <field name="fis_sector_code" readonly="1" string="FIS-kod"/>
                        </group>
                        <group>
                            <field name="ssfta_id"    readonly="1" string="SSFTA ID"/>
                            <field name="hidden"      readonly="1" string="Dold"/>
                            <field name="gold_count"  readonly="1" string="Guldmedaljer"/>
                            <field name="silver_count" readonly="1" string="Silvermedaljer"/>
                            <field name="bronze_count" readonly="1" string="Bronsmedaljer"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ssf_sector_search" model="ir.ui.view">
        <field name="name">ssf.sector.search</field>
        <field name="model">ssf.sector</field>
        <field name="arch" type="xml">
            <search string="Sök grenar">
                <field name="name" string="Namn"/>
                <field name="sector_code" string="Kod"/>
                <filter string="Dölj dolda" name="hide_hidden"
                        domain="[('hidden', '=', False)]"/>
                <separator/>
                <filter string="Säsong 2025/26" name="current_season"
                        domain="[('cs_event_count', '>', 0)]"/>
                <group expand="0" string="Gruppera efter">
                    <filter string="Dold" name="group_hidden"
                            context="{'group_by': 'hidden'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ssf_sector_list" model="ir.actions.act_window">
        <field name="name">Grenar</field>
        <field name="res_model">ssf.sector</field>
        <field name="view_mode">kanban,list,graph,form</field>
        <field name="context">{"create": false, "search_default_hide_hidden": 1, "search_default_current_season": 1}</field>
    </record>

    <record id="view_ssf_discipline_list" model="ir.ui.view">
        <field name="name">ssf.discipline.list</field>
        <field name="model">ssf.discipline</field>
        <field name="arch" type="xml">
            <list string="Discipliner" create="false" edit="false" delete="false">
                <field name="sector_id" string="Gren"/>
                <field name="name" string="Namn"/>
                <field name="short_name" string="Kort namn"/>
                <field name="team_entry" string="Lag"/>
                <field name="hidden" string="Dold"/>
            </list>
        </field>
    </record>
</odoo>

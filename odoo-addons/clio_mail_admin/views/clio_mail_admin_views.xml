<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_clio_mail_admin_form" model="ir.ui.view">
    <field name="name">clio.mail.admin.form</field>
    <field name="model">clio.mail.admin</field>
    <field name="arch" type="xml">
      <form string="Clio Mail Admin">
        <sheet>

          <!-- Snabbknappar -->
          <div class="oe_button_box" name="button_box"/>
          <group string="Kommandon">
            <div class="o_row">
              <button name="action_waiting"   type="object" string="Väntande mail"  class="btn-secondary"/>
              <button name="action_status"    type="object" string="Status"         class="btn-secondary"/>
              <button name="action_whitelist" type="object" string="Vitlista"       class="btn-secondary"/>
            </div>
          </group>

          <!-- Resultat -->
          <group string="Resultat">
            <field name="result_text" widget="text" nolabel="1"
                   invisible="not result_text"
                   style="font-family: monospace; white-space: pre-wrap;"/>
          </group>

          <!-- NCC-lista -->
          <group string="Projektlista / NCC">
            <div class="o_row" style="margin-bottom: 8px;">
              <button name="action_load_ncc" type="object" string="Hämta NCC-lista" class="btn-primary"/>
            </div>
            <field name="ncc_ids" nolabel="1" invisible="not ncc_ids">
              <tree decoration-success="ncc_ok == True"
                    decoration-danger="ncc_ok == False"
                    editable="False"
                    default_order="id">
                <field name="nr"         optional="show"  string="Nr"/>
                <field name="sfar"       optional="show"  string="Sfär"/>
                <field name="kodord"                      string="Kodord"/>
                <field name="name"                        string="Projektnamn"/>
                <field name="ncc_ok"     widget="boolean" string="NCC" readonly="1"/>
                <field name="status_raw" optional="hide"  string="Status"/>
              </tree>
            </field>
          </group>

          <!-- Väntande mail — tree med per-rad-knappar -->
          <group string="Väntande mail">
            <div class="o_row" style="margin-bottom: 8px;">
              <button name="action_load_waiting" type="object" string="Hämta väntande" class="btn-primary"/>
            </div>
            <field name="waiting_ids" nolabel="1" invisible="not waiting_ids">
              <tree editable="False">
                <field name="date_received" string="Datum"     optional="show"/>
                <field name="account"       string="Konto"     optional="show"/>
                <field name="sender"        string="Avsändare"/>
                <field name="subject"       string="Ämne"/>
                <button name="action_vitlista"   type="object" string="Vitlista"
                        icon="fa-check"  class="btn-sm btn-success"/>
                <button name="action_svartlista" type="object" string="Svartlista"
                        icon="fa-ban"    class="btn-sm btn-danger"/>
                <button name="action_behall"     type="object" string="Behåll"
                        icon="fa-clock-o" class="btn-sm btn-secondary"/>
              </tree>
            </field>
          </group>

          <!-- Vitlista / svartlista -->
          <group string="Vitlista / Svartlista">
            <field name="email_input" placeholder="namn@exempel.se"/>
            <div class="o_row">
              <button name="action_whitelist_add" type="object" string="Lägg till vitlista" class="btn-success"/>
              <button name="action_blacklist"     type="object" string="Svartlista"         class="btn-danger"/>
            </div>
          </group>


        </sheet>
      </form>
    </field>
  </record>

  <record id="action_clio_mail_admin" model="ir.actions.act_window">
    <field name="name">Clio Mail Admin</field>
    <field name="res_model">clio.mail.admin</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="context">{'default_result_text': False}</field>
  </record>

</odoo>

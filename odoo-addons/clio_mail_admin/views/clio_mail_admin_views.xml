<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Väntande mail — listvy ─────────────────────────────────────────── -->

  <record id="view_clio_waiting_mail_list" model="ir.ui.view">
    <field name="name">clio.waiting.mail.list</field>
    <field name="model">clio.waiting.mail</field>
    <field name="arch" type="xml">
      <list string="Väntande mail">
        <field name="date_received" string="Datum"     optional="show"/>
        <field name="account"       string="Konto"     optional="show"/>
        <field name="sender"        string="Avsändare"/>
        <field name="subject"       string="Ämne"/>
        <button name="action_vitlista"   type="object" string="Vitlista"
                icon="fa-check"   class="btn-sm btn-success"/>
        <button name="action_svartlista" type="object" string="Svartlista"
                icon="fa-ban"     class="btn-sm btn-danger"/>
        <button name="action_behall"     type="object" string="Behåll"
                icon="fa-clock-o" class="btn-sm btn-secondary"/>
      </list>
    </field>
  </record>

  <record id="view_clio_waiting_mail_search" model="ir.ui.view">
    <field name="name">clio.waiting.mail.search</field>
    <field name="model">clio.waiting.mail</field>
    <field name="arch" type="xml">
      <search string="Sök väntande mail">
        <field name="sender"/>
        <field name="subject"/>
        <separator/>
        <filter name="konto_clio" string="clio@"
                domain="[('account','like','clio')]"/>
        <filter name="konto_ssf"  string="ssf@"
                domain="[('account','like','ssf')]"/>
        <group expand="0" string="Gruppera">
          <filter name="by_account" string="Konto"
                  context="{'group_by': 'account'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_clio_waiting_mail" model="ir.actions.act_window">
    <field name="name">Väntande mail</field>
    <field name="res_model">clio.waiting.mail</field>
    <field name="view_mode">list</field>
    <field name="path">clio-agent-mail</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">Inga väntande mail.</p>
      <p>Klicka <b>Synka från service</b> i kugghjulsmenyn för att hämta aktuell lista.</p>
    </field>
  </record>

  <!-- Server action: Synka från service -->
  <record id="action_sync_waiting_from_service" model="ir.actions.server">
    <field name="name">Synka från service</field>
    <field name="model_id" ref="model_clio_waiting_mail"/>
    <field name="binding_model_id" ref="model_clio_waiting_mail"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">model.action_sync_from_service()</field>
  </record>

  <!-- Server action: Vitlista valda -->
  <record id="action_bulk_vitlista_waiting" model="ir.actions.server">
    <field name="name">Vitlista valda</field>
    <field name="model_id" ref="model_clio_waiting_mail"/>
    <field name="binding_model_id" ref="model_clio_waiting_mail"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">records.action_vitlista()</field>
  </record>

  <!-- Server action: Svartlista valda -->
  <record id="action_bulk_svartlista_waiting" model="ir.actions.server">
    <field name="name">Svartlista valda</field>
    <field name="model_id" ref="model_clio_waiting_mail"/>
    <field name="binding_model_id" ref="model_clio_waiting_mail"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">records.action_svartlista()</field>
  </record>

  <!-- ── Kommandon — formulärvy (vitlista, svartlista, intervju, status) ── -->

  <record id="view_clio_mail_admin_form" model="ir.ui.view">
    <field name="name">clio.mail.admin.form</field>
    <field name="model">clio.mail.admin</field>
    <field name="arch" type="xml">
      <form string="Kommandon">
        <sheet>

          <group string="Status">
            <div class="o_row">
              <button name="action_status"    type="object" string="Status"    class="btn-secondary"/>
              <button name="action_whitelist" type="object" string="Visa vitlista" class="btn-secondary"/>
            </div>
            <field name="result_text" widget="text" nolabel="1"
                   invisible="not result_text"
                   style="font-family: monospace; white-space: pre-wrap;"/>
          </group>

          <group string="Vitlista / Svartlista">
            <field name="email_input" placeholder="namn@exempel.se"/>
            <div class="o_row">
              <button name="action_whitelist_add" type="object" string="Vitlista" class="btn-success"/>
              <button name="action_blacklist"     type="object" string="Svartlista" class="btn-danger"/>
            </div>
          </group>

          <group string="Intervju">
            <field name="interview_to"      placeholder="mottagare@exempel.se"/>
            <field name="interview_subject"/>
            <field name="interview_context" placeholder="Kontext att skicka med (valfritt)"/>
            <div class="o_row">
              <button name="action_interview_start" type="object" string="Starta intervju" class="btn-primary"/>
              <button name="action_interview_stop"  type="object" string="Avsluta intervju" class="btn-secondary"/>
            </div>
          </group>

        </sheet>
      </form>
    </field>
  </record>

  <record id="action_clio_mail_admin" model="ir.actions.act_window">
    <field name="name">Kommandon</field>
    <field name="res_model">clio.mail.admin</field>
    <field name="view_mode">form</field>
    <field name="context">{'default_result_text': False}</field>
  </record>

</odoo>

# clio-agent-mail/.env.example
# Endast mail-specifika hemligheter — IMAP-lösenord för Misshosting.
#
# ANTHROPIC_API_KEY och NOTION_API_KEY hämtas från root-nivåns .env
# (C:\Users\Fredrik Arvas\Documents\git\clio-tools\.env)
#
# Kopiera denna fil till .env och fyll i värdena.

# IMAP/SMTP-lösenord för clio@arvas.international
IMAP_PASSWORD_CLIO=

# IMAP/SMTP-lösenord för info@arvas.international
# Samma som CLIO om båda kontona delar lösenord på Misshosting
IMAP_PASSWORD_INFO=

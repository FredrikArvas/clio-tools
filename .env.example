# .env.example
# Kopiera till .env och fyll i dina nycklar.
# Kör 'python clio.py setup' för guidad konfiguration.
# OBS: Checka ALDRIG in .env i git.

# Anthropic API-nyckel — hämta på https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Notion API-nyckel — hämta på https://www.notion.so/my-integrations
NOTION_API_KEY=

# ElevenLabs API-nyckel (valfri) — hämta på https://elevenlabs.io/
ELEVENLABS_API_KEY=

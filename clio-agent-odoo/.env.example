# ── Odoo-anslutning (Clio Bot-användaren) ──────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=aiab
ODOO_BOT_LOGIN=clio-bot
# Lösenord: kopiera från Odoo → Inställningar → Teknisk → Systemparametrar
# Sök på nyckeln: clio_discuss.bot_password
ODOO_BOT_PASSWORD=

# ── Delad hemlighet — måste matcha clio_discuss.shared_secret i Odoo ────────
CLIO_ODOO_SECRET=

# ── Behörighet ───────────────────────────────────────────────────────────────
# Kommaseparerade admin-adresser (alltid tillåtna, full access)
CLIO_ADMIN_EMAILS=fredrik@arvas.se

# Extra tillåtna adresser utöver admin (write-nivå)
CLIO_ALLOWED_EMAILS=

# Om du har clio_access-matrisen i Notion — lämna tom för enkel e-postlista
CLIO_ACCESS_MATRIX_PAGE_ID=

# ── Agent-konfiguration ──────────────────────────────────────────────────────
CLIO_ODOO_HOST=127.0.0.1
CLIO_ODOO_PORT=8100
CLIO_MODEL=claude-sonnet-4-6

# ── API-nycklar (ärvs från root .env om inte åsidosätts här) ────────────────
# ANTHROPIC_API_KEY=
# NOTION_API_KEY=
